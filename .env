# ─────────────────────────────────────────────
# Sistema AEE — Variáveis de Ambiente (Exemplo)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=aee_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=aee_db

# FastAPI / JWT
SECRET_KEY=troque_esta_chave_secreta_com_pelo_menos_32_caracteres
JWT_TTL_HOURS=8

# Ambiente
ENVIRONMENT=development

# URL de conexão (montada pelo docker-compose — não edite em dev)
# DATABASE_URL=postgresql+asyncpg://aee_user:senha@db:5432/aee_db
